# ─── Ambiente: PRODUCCIÓN (prod) — PLANTILLA ─────────────────────────────────
# Este archivo es la PLANTILLA. El archivo real (.env.prod) está en .gitignore.
# Pasos:
#   cp envs/.env.prod.example envs/.env.prod
#   # Editar .env.prod con las credenciales y dominio reales
COMPOSE_PROJECT_NAME=inv-prod

# ─── Base de datos ───────────────────────────────────────────────────────────
# CAMBIAR antes de desplegar.
DB_NAME=inventory_prod
DB_USER=prod_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SCHEMA=sysinventarios
DDL_AUTO=update
# DB_HOST_PORT no definido → la BD NO se expone al host en producción

# ─── Frontend ────────────────────────────────────────────────────────────────
# CAMBIAR al dominio o IP pública del servidor.
# Esta URL la usa el NAVEGADOR del usuario para llamar al backend.
# Requiere reconstruir la imagen si cambia (Next.js la incrusta en el bundle).
NEXT_PUBLIC_API_BASE_URL=http://your-server.com:8080
NEXT_PUBLIC_LOGO=/img/Testing_LOGO.png
NEXT_PUBLIC_SITE_TITLE=TuZonaPCGamer
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer

# ─── Puertos en el host ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
