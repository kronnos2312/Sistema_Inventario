# ─── Ambiente: PRUEBAS (test) ────────────────────────────────────────────────
# Archivo seguro de commitear: solo contiene credenciales de prueba.
# IMPORTANTE: ejecutar `make down-test` (o down -v) al terminar para limpiar el volumen.
COMPOSE_PROJECT_NAME=inv-test

# ─── Base de datos ───────────────────────────────────────────────────────────
DB_NAME=inventory_test
DB_USER=testuser
DB_PASSWORD=testpassword
DB_SCHEMA=sysinventarios_test
DB_HOST_PORT=5434          # puerto aislado para correr en paralelo con dev
DDL_AUTO=create-drop       # BD limpia en cada arranque

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_LOGO=/img/Testing_LOGO.png
NEXT_PUBLIC_SITE_TITLE=TuZonaPCGamer [TEST]
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer

# ─── Puertos en el host ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
