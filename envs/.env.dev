# ─── Ambiente: DESARROLLO (dev) ──────────────────────────────────────────────
# Archivo seguro de commitear: solo contiene credenciales locales de prueba.
COMPOSE_PROJECT_NAME=inv-dev

# ─── Base de datos ───────────────────────────────────────────────────────────
DB_NAME=inventory_dev
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios
DB_HOST_PORT=5433          # puerto diferente al default para no chocar con PostgreSQL local
DDL_AUTO=update

# ─── Frontend ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL se incrusta en el bundle al compilar.
# Cambiar SOLO si el backend no corre en localhost:8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_LOGO=/img/logo.png
NEXT_PUBLIC_SITE_TITLE=TuZonaPCGamer [DEV]
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer

# ─── Puertos en el host ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
