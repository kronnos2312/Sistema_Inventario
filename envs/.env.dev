# ─── Ambiente: DESARROLLO (dev) ──────────────────────────────────────────────
COMPOSE_PROJECT_NAME=inv-dev

# ─── Base de datos ───────────────────────────────────────────────────────────
DB_NAME=inventory_dev
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios
DB_HOST_PORT=5433
DDL_AUTO=update
DB_DATA_DIR=./data/postgres

# ─── Archivos / Documentos ───────────────────────────────────────────────────
FILES_DIR=D:/desarrollo/proyectos/sys_inventarios/archivos/san

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
LOGO_DIR=D:/desarrollo/proyectos/sys_inventarios/archivos/logo/sistema
NEXT_PUBLIC_LOGO=/logo/logo.png
NEXT_PUBLIC_SITE_TITLE=Sistema De Inventario & ventas [DEV]
NEXT_PUBLIC_SITE_CLIENT=pruebas

# ─── Puertos expuestos en el host ────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_HOST_PORT=5432

HOST_IP=192.168.10.10
