# Build stage
FROM node:18-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_LOGO
ARG NEXT_PUBLIC_SITE_TITLE
ARG NEXT_PUBLIC_SITE_CLIENT
ARG INTERNAL_API_URL

ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_LOGO=$NEXT_PUBLIC_LOGO
ENV NEXT_PUBLIC_SITE_TITLE=$NEXT_PUBLIC_SITE_TITLE
ENV NEXT_PUBLIC_SITE_CLIENT=$NEXT_PUBLIC_SITE_CLIENT
ENV INTERNAL_API_URL=$INTERNAL_API_URL

RUN npm run build

# Production stage
FROM node:18-alpine AS runner
WORKDIR /app

COPY --from=builder /app ./

EXPOSE 3000
CMD ["npm", "start"]
