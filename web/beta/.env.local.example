# Copia este archivo a .env.local para desarrollo del frontend SIN Docker.
#   cp .env.local.example .env.local
#
# Nota: solo aplica cuando corres `yarn dev`/`yarn build` directamente en
# web/beta. Cuando el frontend corre vía Docker Compose (ver README raíz),
# estas variables las define docker-compose.yml/.env.{perfil} en su lugar y
# NEXT_PUBLIC_API_BASE_URL queda fijo a /api-proxy (no se usa este archivo).

# URL del backend accesible desde el navegador.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Título y cliente mostrados en la interfaz y metadatos de la página.
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer

# Descripción usada en metadatos (opcional).
NEXT_PUBLIC_SITE_DESCRIPTION=

# Ruta del logo por defecto si el backend no tiene uno configurado (opcional).
# NEXT_PUBLIC_LOGO=/logo/logo.png
