# Perfil DEV — desarrollo local.
# Uso:
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.expose-db.yml up --build

SPRING_PROFILE=dev

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=inventory
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios
DB_DATA_DIR=./data/postgres
# Puerto expuesto al host solo si se incluye docker-compose.expose-db.yml.
DB_HOST_PORT=5432

# ── Archivos ──────────────────────────────────────────────────────────────────
FILES_DIR=./data/files

# ── Puertos ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL NO se declara aquí: en el flujo Docker queda fijo a
# /api-proxy dentro de docker-compose.yml. Para desarrollo del frontend sin
# Docker, usa web/beta/.env.local (ver web/beta/.env.local.example).
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario (dev)
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer
NEXT_PUBLIC_SITE_DESCRIPTION=

# ── Seguridad / JWT ───────────────────────────────────────────────────────────
# Secreto de desarrollo, no sensible — nunca usar en prod.
JWT_SECRET=dev-secret-not-for-production-use-only
JWT_EXPIRATION_MS=86400000
ADMIN_DEFAULT_PASSWORD=admin123
