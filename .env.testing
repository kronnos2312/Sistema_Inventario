# Perfil TESTING.
# Uso:
#   docker compose --env-file .env.testing -f docker-compose.yml -f docker-compose.expose-db.yml up --build
#
# ⚠️  Comparte a propósito la misma base de datos que "dev" (mismo DB_NAME y
# DB_DATA_DIR). Como este perfil usa ddl-auto=create-drop (ver
# application-testing.properties), CADA arranque/parada de este perfil BORRA
# el esquema y los datos de desarrollo. No lo uses si tienes datos de dev que
# quieras conservar.

SPRING_PROFILE=testing

# ── Base de datos (misma que dev — ver advertencia arriba) ────────────────────
DB_NAME=inventory
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios
DB_DATA_DIR=./data/postgres
DB_HOST_PORT=5432

# ── Archivos ──────────────────────────────────────────────────────────────────
FILES_DIR=./data/files

# ── Puertos ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL NO se declara aquí: en el flujo Docker queda fijo a
# /api-proxy dentro de docker-compose.yml. Para desarrollo del frontend sin
# Docker, usa web/beta/.env.local (ver web/beta/.env.local.example).
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario (testing)
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer
NEXT_PUBLIC_SITE_DESCRIPTION=

# ── Seguridad / JWT ───────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-not-for-production-use-only
JWT_EXPIRATION_MS=86400000
ADMIN_DEFAULT_PASSWORD=admin123
