# Copia este archivo a .env y ajusta los valores.
#   cp .env.example .env
#
# Para trabajar con perfiles de entorno (dev/testing/prod) usa en su lugar
# los archivos .env.dev, .env.testing o .env.prod ya incluidos en el repo:
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.expose-db.yml up --build
# Ver la sección "Perfiles de entorno" del README para más detalle.

# dev | testing | prod — activa server/beta/src/main/resources/application-{perfil}.properties
SPRING_PROFILE=dev

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=inventory
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios

# Ruta en el SO donde PostgreSQL persiste sus datos.
# Relativa al docker-compose.yml o absoluta.
# Windows: DB_DATA_DIR=C:/inventario/postgres
# Linux:   DB_DATA_DIR=/opt/inventario/postgres
DB_DATA_DIR=./data/postgres

# Puerto expuesto al host para PostgreSQL — solo tiene efecto si se incluye
# docker-compose.expose-db.yml (ver README). En prod no se expone.
DB_HOST_PORT=5432

# ── Archivos ──────────────────────────────────────────────────────────────────
# Carpeta donde el backend almacena los archivos subidos (logos, documentos...).
# Windows: FILES_DIR=C:/inventario/files
# Linux:   FILES_DIR=/opt/inventario/files
FILES_DIR=./data/files

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
JWT_SECRET=change-me-in-prod-please-32-bytes-min
JWT_EXPIRATION_MS=86400000
ADMIN_DEFAULT_PASSWORD=admin123

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL NO se declara aquí: en el flujo Docker queda fijo a
# /api-proxy dentro de docker-compose.yml (ver README). Para desarrollo del
# frontend sin Docker, usa web/beta/.env.local (ver web/beta/.env.local.example).
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer
NEXT_PUBLIC_SITE_DESCRIPTION=
FRONTEND_PORT=3000
