# Copia este archivo a .env y ajusta los valores para tu entorno.
# cp .env.example .env

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_NAME=mydatabase
DB_USER=myuser
DB_PASSWORD=mypassword
DB_PORT=5432

# Nombre del schema PostgreSQL donde Hibernate crea las tablas.
# Debe coincidir con SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA.
DB_SCHEMA=sysinventarios

# Estrategia DDL de Hibernate: update | validate | create | create-drop | none
DDL_AUTO=update

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# URL pública del backend accesible desde el NAVEGADOR del usuario.
# Si el contenedor corre en localhost, mantener http://localhost:8080.
# Para producción: http://tu-servidor.com:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

NEXT_PUBLIC_LOGO=/img/Testing_LOGO.png
NEXT_PUBLIC_SITE_TITLE=TuZonaPCGamer
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer

# ─── Puertos expuestos en el host ────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_HOST_PORT=5432
