# Copia este archivo a .env y ajusta los valores.
#   cp .env.example .env

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=inventory
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios

# Estrategia DDL de Hibernate: update | validate | create | create-drop | none
DDL_AUTO=update

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Con Docker: no tocar NEXT_PUBLIC_API_BASE_URL — el proxy interno lo maneja.
# Sin Docker (dev local): descomentar y apuntar al backend local.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_LOGO=/img/logo.png
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer
FRONTEND_PORT=3000

# ── Módulo de configuración (red local / QR) ──────────────────────────────────
# IP real del host para el generador de QR cuando se corre con Docker.
# Docker no puede ver las interfaces del host, por eso se pasa manualmente.
# Ejemplo: HOST_IP=192.168.1.100
# Si se deja vacío, se detecta automáticamente (solo funciona sin Docker).
HOST_IP=
