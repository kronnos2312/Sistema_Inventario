# Copia este archivo a .env y ajusta los valores.
#   cp .env.example .env

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_NAME=inventory
DB_USER=myuser
DB_PASSWORD=mypassword
DB_SCHEMA=sysinventarios

# Ruta completa al archivo de logo en el SO (usar barras /).
# Windows: LOGO_FILE=D:/mis-logos/logo.png
# Linux:   LOGO_FILE=/opt/inventario/logo.png
LOGO_FILE=./logo/logo.png

# Ruta en el SO donde PostgreSQL persiste sus datos.
# Relativa al docker-compose.yml o absoluta.
# Windows: DB_DATA_DIR=C:/inventario/postgres
# Linux:   DB_DATA_DIR=/opt/inventario/postgres
DB_DATA_DIR=./data/postgres

# Estrategia DDL de Hibernate: update | validate | create | create-drop | none
DDL_AUTO=update

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Con Docker: no tocar NEXT_PUBLIC_API_BASE_URL — el proxy interno lo maneja.
# Sin Docker (dev local): descomentar y apuntar al backend local.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SITE_TITLE=Sistema Inventario
NEXT_PUBLIC_SITE_CLIENT=TuZona PC Gamer
FRONTEND_PORT=3000

# ── Módulo de configuración (red local / QR) ──────────────────────────────────
# IP real del host — se usa en el generador de QR tanto en Docker como en dev.
# Con Docker: docker-compose la pasa al contenedor frontend automáticamente.
# Sin Docker: copiar también HOST_IP, HOST_PORT y HOST_PORT_BACKEND a web/beta/.env.local
# Ejemplo: HOST_IP=192.168.1.100
HOST_IP=
